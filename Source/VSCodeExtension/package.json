{
    "name": "narrator",
    "displayName": "Narrator - Chronicle Explorer",
    "description": "Browse and explore Cratis Chronicle event stores directly from VS Code",
    "version": "0.1.0",
    "publisher": "cratis",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "narrator",
                    "title": "Narrator",
                    "icon": "resources/icons/chronicle.svg"
                }
            ]
        },
        "views": {
            "narrator": [
                {
                    "id": "narratorExplorer",
                    "name": "Chronicle Explorer"
                }
            ]
        },
        "commands": [
            {
                "command": "narrator.refresh",
                "title": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "narrator.connect",
                "title": "Connect to Chronicle"
            },
            {
                "command": "narrator.setContext",
                "title": "Set Active Context"
            },
            {
                "command": "narrator.openSettings",
                "title": "Open Narrator Settings"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "narrator.refresh",
                    "when": "view == narratorExplorer",
                    "group": "navigation"
                },
                {
                    "command": "narrator.connect",
                    "when": "view == narratorExplorer",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "Narrator",
            "properties": {
                "narrator.configPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the CLI config file. Leave empty to auto-detect from ~/.cratis/config.json"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.3.0",
        "@vscode/vsce": "^2.22.0",
        "esbuild": "^0.20.0"
    },
    "dependencies": {
        "@cratis/chronicle.contracts": "^15.22.13"
    }
}
