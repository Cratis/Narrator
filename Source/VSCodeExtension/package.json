{
    "name": "narrator",
    "displayName": "Narrator - Chronicle Explorer",
    "description": "Browse and explore Cratis Chronicle event stores directly from VS Code",
    "version": "0.1.0",
    "publisher": "cratis",
    "icon": "resources/logo.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "narrator",
                    "title": "Narrator",
                    "icon": "resources/icons/chronicle.svg"
                }
            ]
        },
        "views": {
            "narrator": [
                {
                    "id": "narratorExplorer",
                    "name": "Chronicle Explorer"
                },
                {
                    "id": "narratorDetails",
                    "name": "Details"
                }
            ]
        },
        "commands": [
            {
                "command": "narrator.refresh",
                "title": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "narrator.connect",
                "title": "Connect to Chronicle"
            },
            {
                "command": "narrator.setContext",
                "title": "Set Active Context"
            },
            {
                "command": "narrator.openSettings",
                "title": "Open Narrator Settings"
            },
            {
                "command": "narrator.addContext",
                "title": "Add Context",
                "icon": "$(add)"
            },
            {
                "command": "narrator.editContext",
                "title": "Edit Context",
                "icon": "$(edit)"
            },
            {
                "command": "narrator.deleteContext",
                "title": "Delete Context",
                "icon": "$(trash)"
            },
            {
                "command": "narrator.activateContext",
                "title": "Set as Active",
                "icon": "$(check)"
            },
            {
                "command": "narrator.openEventTypeSchema",
                "title": "Open Schema",
                "icon": "$(json)"
            },
            {
                "command": "narrator.openReadModelSchema",
                "title": "Open Schema",
                "icon": "$(json)"
            },
            {
                "command": "narrator.openProjectionDeclaration",
                "title": "Open Declaration",
                "icon": "$(file-code)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "narrator.refresh",
                    "when": "view == narratorExplorer",
                    "group": "navigation"
                },
                {
                    "command": "narrator.addContext",
                    "when": "view == narratorExplorer",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "narrator.activateContext",
                    "when": "view == narratorExplorer && viewItem == context",
                    "group": "inline@1"
                },
                {
                    "command": "narrator.editContext",
                    "when": "view == narratorExplorer && viewItem =~ /^context/",
                    "group": "1_manage@1"
                },
                {
                    "command": "narrator.deleteContext",
                    "when": "view == narratorExplorer && viewItem =~ /^context/",
                    "group": "1_manage@2"
                },
                {
                    "command": "narrator.openEventTypeSchema",
                    "when": "view == narratorExplorer && viewItem == eventType",
                    "group": "inline@1"
                },
                {
                    "command": "narrator.openReadModelSchema",
                    "when": "view == narratorExplorer && viewItem == readModelType",
                    "group": "inline@1"
                },
                {
                    "command": "narrator.openProjectionDeclaration",
                    "when": "view == narratorExplorer && viewItem == projection",
                    "group": "inline@1"
                }
            ]
        },
        "configuration": {
            "title": "Narrator",
            "properties": {
                "narrator.configPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the CLI config file. Leave empty to auto-detect from ~/.cratis/config.json"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "node esbuild.mjs --production",
        "compile": "node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint --cache --quiet --fix",
        "lint:ci": "eslint --cache --quiet",
        "test": "vitest run",
        "ci": "yarn lint:ci && yarn compile && yarn typecheck && yarn test"
    },
    "devDependencies": {
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@tony.ganchev/eslint-plugin-header": "^3.4.4",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "8.59.1",
        "@typescript-eslint/parser": "8.59.1",
        "@vscode/vsce": "^2.22.0",
        "esbuild": "^0.20.0",
        "eslint": "10.2.1",
        "globals": "17.5.0",
        "typescript": "^5.3.0",
        "typescript-eslint": "8.59.1",
        "vitest": "4.1.5"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.12.0",
        "@cratis/chronicle.contracts": "15.22.13"
    },
    "packageManager": "yarn@4.14.1"
}
