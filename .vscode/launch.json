{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Source/VSCodeExtension"
            ],
            "outFiles": [
                "${workspaceFolder}/Source/VSCodeExtension/out/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}",
            "sourceMaps": true
        },
        {
            "name": "Run Extension (no build)",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/Source/VSCodeExtension"
            ],
            "outFiles": [
                "${workspaceFolder}/Source/VSCodeExtension/out/**/*.js"
            ],
            "sourceMaps": true
        }
    ]
}
